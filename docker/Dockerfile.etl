FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements and install
COPY src/requirements.txt /app/
RUN pip install --no-cache-dir -r /app/requirements.txt

# Copy ETL code
COPY src/ /app/src/
COPY scripts/etl_runner.py /app/scripts/

# Create directories
RUN mkdir -p /var/log/etl /data/logs

ENV PYTHONPATH=/app

CMD ["python", "/app/scripts/etl_runner.py"]
